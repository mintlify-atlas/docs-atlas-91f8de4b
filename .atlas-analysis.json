  "keyFeatures": [
    "Structured logging with typed fields (String, Int, Err, etc.)",
    "Multiple formatters (TextFormatter for dev, JSONFormatter for production)",
    "Child loggers with field propagation",
    "Context propagation (trace_id, span_id)",
    "Extensible hooks system (Slack, Sentry, OpenTelemetry, Syslog)",
    "Rotating file writer with compression and time-based rotation",
    "Automatic redaction of sensitive data",
    "Caller info and stack traces",
    "Async logging for high-throughput scenarios",
    "Dynamic log level via HTTP endpoints",
    "Testing utilities (MockLogger, CaptureBuffer)",
    "Zero-allocation field creation",
    "100% backward compatible with v2 API"
  ],
